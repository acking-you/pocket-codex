# Secret backend configuration. Install at /etc/pocket-codex/backend.env,
# chmod 0600, chown pcx:pcx. Loaded by systemd (EnvironmentFile) as PCX_-prefixed
# env vars that override backend.toml.

# The REAL 32-byte pb-mapper MSG_HEADER_KEY (same value the relay uses). This
# never leaves the server — clients only ever hold a session token.
PCX_MSG_HEADER_KEY=replace-with-the-32-byte-relay-key

# HS256 secret for signing session JWTs (generate: openssl rand -hex 32).
PCX_JWT_SECRET=replace-with-a-long-random-secret

# GitHub OAuth app client id (Device Flow enabled). The app has no client
# secret in the device flow, but keep this here for consistency.
PCX_GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
