# Rust build artefacts
target/
**/target/

# Cargo lock for the workspace is intentionally checked in (binary crate).

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Logs
*.log

# Local environment overrides
.env
.env.local
.env.*.local

# Backup / temp files
*.bak
*.tmp
tmp/
.local/

# Coverage reports
coverage/
*.profdata
*.profraw

# Flutter / Dart build output (kept under apps/flutter)
apps/flutter/**/build/
apps/flutter/**/.dart_tool/
apps/flutter/**/.flutter-plugins
apps/flutter/**/.flutter-plugins-dependencies
apps/flutter/**/.packages
apps/flutter/**/pubspec.lock
# ...but the app's own lock IS committed for reproducible builds (spec §8);
# only nested package locks (e.g. rust_builder/) stay ignored.
!apps/flutter/pubspec.lock

# Worktrees
.worktrees/

# Local note files (never committed)
pocket-codex-codex-raw-dialogue.md

# Visual-companion brainstorm scratch (not source)
.superpowers/

# Python bytecode cache (local script runs)
__pycache__/
